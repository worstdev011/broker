# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/binary_options_db
# Optional: connection pool (auto-appended to URL if not present)
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT=20
DATABASE_CONNECT_TIMEOUT=10

# Security (REQUIRED in production)
COOKIE_SECRET=your-secure-random-string-min-32-chars
FRONTEND_URL=http://localhost:3000
# Locale prefix for server redirects after OAuth (match next-intl defaultLocale, e.g. ru)
FRONTEND_DEFAULT_LOCALE=ru

# Google Sign-In (optional - omit to disable /api/auth/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OAuth return redirects use this URL's origin (path must be your callback route)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Admin emails (comma-separated) - для админских эндпоинтов (PATCH payout и т.д.)
ADMIN_EMAILS=admin@example.com

# File uploads (avatars) - max size in bytes, default 5MB
MAX_UPLOAD_SIZE=5242880

# FLOW R: Real Market Prices (xchangeapi.com) - REQUIRED in production if using Real instruments
XCHANGE_API_KEY=your-xchange-api-key

# Bull job queues + PriceStore/CandleStore - when set, uses Redis; otherwise defaults to redis://127.0.0.1:6379
# Use Redis protocol URL: redis://127.0.0.1:6379 or rediss:// for Upstash/TLS
REDIS_URL=redis://127.0.0.1:6379

# BetaTransfer (UAH, Card) - без ключей POST /api/wallet/deposit|withdraw вернут 503 PAYMENT_NOT_CONFIGURED
BETATRANSFER_PUBLIC_KEY=
BETATRANSFER_SECRET_KEY=
# Публичный URL вебхука (подсказка для кабинета BetaTransfer): https://your-api.com/api/wallet/webhook
BETATRANSFER_WEBHOOK_URL=
